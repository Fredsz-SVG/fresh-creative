# Salin file ini menjadi `.dev.vars` (folder hono-backend).
# Ini SATU-SATUNYA file env lokal yang dibaca Wrangler untuk `wrangler dev`.
# File `.env` di folder ini TIDAK dipakai Worker — jangan dipakai untuk secret.

NODE_ENV=development

FIREBASE_PROJECT_ID=

# Try On: google/gemini-2.5-flash + google/gemini-2.5-flash-image (satu token Replicate).
REPLICATE_API_TOKEN=

RESEND_API_KEY=
RESEND_FROM_EMAIL=

NEXT_PUBLIC_APP_URL=

XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

SKIP_LOGIN_OTP=
SKIP_OTP=
