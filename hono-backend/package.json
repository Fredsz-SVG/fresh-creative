{
  "name": "hono-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "worker.ts",
  "scripts": {
    "dev": "wrangler dev worker.ts --remote",
    "dev:remote": "wrangler dev worker.ts --remote",
    "dev:local": "wrangler dev worker.ts --local",
    "build": "wrangler build",
    "deploy": "wrangler deploy --keep-vars",
    "types:cf": "wrangler types --include-runtime=false",
    "start": "wrangler start",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "release:perf-check": "node scripts/release-perf-check.mjs",
    "d1:seed-wilayah": "node scripts/build-d1-ref-wilayah.mjs",
    "d1:sync-users-from-supabase": "node scripts/sync-supabase-users-to-d1.mjs",
    "d1:sync-users-from-supabase:local": "node scripts/sync-supabase-users-to-d1.mjs --local"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "fresh-creative-saas": "file:..",
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "replicate": "^1.4.0",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260329.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.9.3",
    "vitest": "^1.2.2",
    "wrangler": "^4.81.0"
  }
}
