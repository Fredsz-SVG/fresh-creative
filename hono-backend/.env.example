# ============================================
# HONO BACKEND - ENVIRONMENT VARIABLES
# ============================================

# Cloudflare Workers tidak support .env secara langsung,
# tapi gunakan file ini untuk development (via dotenv atau import.meta.env)

PORT=8787
NODE_ENV=development

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI
REPLICATE_API_TOKEN=

# EMAIL (RESEND)
RESEND_API_KEY=

# APP
NEXT_PUBLIC_APP_URL=

# XENDIT PAYMENT
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# OTP
SKIP_LOGIN_OTP=
