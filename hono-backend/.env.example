# ============================================
# HONO BACKEND - ENVIRONMENT VARIABLES
# ============================================

# Production: set di Cloudflare Dashboard atau via `wrangler secret put` (rahasia).
# Lokal Wrangler: salin ke `.dev.vars` (lihat `.dev.vars.example`).

PORT=8787
NODE_ENV=development

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI
REPLICATE_API_TOKEN=

# EMAIL (RESEND)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# APP
NEXT_PUBLIC_APP_URL=

# XENDIT PAYMENT
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# OTP (otp-status membaca SKIP_OTP atau SKIP_LOGIN_OTP)
SKIP_LOGIN_OTP=
SKIP_OTP=
