# ═══════════════════════════════════════════════════════════════════
# PENTING — Cloudflare Workers / Wrangler TIDAK memuat file `.env`
# ═══════════════════════════════════════════════════════════════════
# Lokal: salin blok di bawah ke file `.dev.vars` (satu folder dengan wrangler.toml).
#        Wrangler otomatis memuat `.dev.vars` saat `npm run dev` / `wrangler dev`.
#        Jangan commit `.dev.vars` (sudah di .gitignore).
#
# Production: set di Cloudflare Dashboard → Workers → Settings → Variables,
#             atau `wrangler secret put NAMA_SECRET`
#
# D1 & R2: binding di wrangler.toml (bukan string env).
# ═══════════════════════════════════════════════════════════════════

NODE_ENV=development

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

REPLICATE_API_TOKEN=

RESEND_API_KEY=
RESEND_FROM_EMAIL=

NEXT_PUBLIC_APP_URL=

XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

SKIP_LOGIN_OTP=
SKIP_OTP=
