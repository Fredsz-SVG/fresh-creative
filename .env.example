# ============================================
# NEXT.JS (frontend) — salin ke .env.local
# ============================================
# D1 / R2 / JWT Worker JANGAN disini; itu di Cloudflare (Wrangler / Dashboard).

# Supabase Auth (browser + server client pakai anon key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# URL aplikasi Next (redirect, link absolut)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Hono di Cloudflare Workers (dev: wrangler biasanya :8787)
NEXT_PUBLIC_API_URL=http://localhost:8787

# Server-only: dipakai beberapa route Next (auth callback, api-helpers admin) —
# JANGAN pakai prefix NEXT_PUBLIC_. Setelah semua data lewat Hono saja, bisa dihapus.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Opsional: Redis (hanya jika fitur yang memakai lib/redis.ts aktif)
# REDIS_URL=redis://localhost:6379

# Opsional: debug request timing (lib/api-timing.ts)
# DEBUG_API_TIMING=1

# ============================================
# Backend terpisah: hono-backend/.env.example
# (Wrangler: salin ke .dev.vars — RESEND, XENDIT, REPLICATE, SUPABASE_JWT_SECRET, dll.)
# ============================================
